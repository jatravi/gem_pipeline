# ============================================================
# GeM Tender Discovery & Extraction Pipeline
# Environment Configuration
# Copy this file to .env and update the values.
# ============================================================

# ============================================================
# Runtime
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO

# ============================================================
# PostgreSQL Database
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gem_pipeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# ============================================================
# Storage
# ============================================================
DATA_DIR=data
RAW_GEM_DIR=data/raw/gem

# ============================================================
# LLM Provider
#
# Supported values:
#   - openai
#   - ollama
#   - fake
#   - gemini
# ============================================================
LLM_PROVIDER=ollama

# ============================================================
# OpenAI Configuration
#
# Used only when LLM_PROVIDER=openai
# ============================================================
LLM_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini

# ============================================================
# Ollama Configuration
#
# Used only when LLM_PROVIDER=ollama
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# ============================================================
# Gemini Configuration
#
# Used only when LLM_PROVIDER=gemini
# ============================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ============================================================
# LLM Settings
# ============================================================
LLM_MAX_INPUT_CHARS=15000
LLM_FALLBACK_TO_FAKE_ON_ERROR=true

# ============================================================
# Token Cost Configuration (INR per 1K tokens)
#
# Local Ollama models generally incur no API cost, so these
# values are mainly used for OpenAI cost estimation.
# ============================================================
LLM_INPUT_COST_PER_1K_TOKENS_INR=0.02
LLM_OUTPUT_COST_PER_1K_TOKENS_INR=0.08